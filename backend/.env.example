# ─── Server Configuration ────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Configuration ───────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/employee_management?appName=Cluster0

# ─── JWT Configuration ───────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=30d

# ─── CORS Configuration ─────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
